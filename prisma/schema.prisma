generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Ward {
  id                    String   @id @default(cuid())
  name                  String
  nameHi                String?
  nameTe                String?
  lat                   Float
  lng                   Float
  population            Int
  literacyRate          Float
  unemploymentRate      Float
  schoolEnrollment      Int
  schoolCapacity        Int
  nearestSchoolKm       Float
  nearestHospitalKm     Float
  householdsNoPipedWater Int
  households            Int
  electricityGapPct     Float
  roadGapScore          Float
  housingGapPct         Float

  submissions Submission[]
  proposals   Proposal[]

  createdAt DateTime @default(now())
}

enum Channel {
  text
  voice
  photo
  whatsapp
}

enum Category {
  education
  healthcare
  roads_transport
  water_sanitation
  electricity
  employment_vocational
  housing
  agriculture
  public_safety
  other
}

enum Sentiment {
  positive
  neutral
  negative
}

enum SubmissionStatus {
  pending
  analyzed
  error
}

model Submission {
  id       String  @id @default(cuid())
  channel  Channel @default(text)

  rawText     String?
  language    String?
  translatedText String?

  photoDataUrl String?
  photoDescription String?

  audioDataUrl String?

  category  Category?
  urgency   Int?
  sentiment Sentiment?
  summary   String?

  status       SubmissionStatus @default(pending)
  errorMessage String?

  citizenName String?
  lat         Float?
  lng         Float?
  wardId      String?
  ward        Ward? @relation(fields: [wardId], references: [id])

  createdAt DateTime @default(now())
}

model Proposal {
  id          String   @id @default(cuid())
  title       String
  description String
  category    Category
  estCostLakh Float
  wardId      String?
  ward        Ward?    @relation(fields: [wardId], references: [id])
  source      String   @default("development_plan")
  createdAt   DateTime @default(now())
}
